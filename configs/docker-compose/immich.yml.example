# Immich Photo Management Docker Compose (Phase 4)
# Copy to immich.yml and deploy:
#   docker compose --env-file foundation.env --env-file services.env --env-file secrets.env -f immich.yml up -d
# Requires: foundation.env (TIMEZONE)
# Requires: services.env (IMMICH_VERSION, UPLOAD_LOCATION, DB_DATA_LOCATION, MEDIA_GROUP_GID, DB_USERNAME, DB_DATABASE_NAME)
# Requires: secrets.env (DB_PASSWORD)
# Reference: .kiro/specs/04-photo-management/design.md

services:
  immich-server:
    image: ghcr.io/immich-app/immich-server:${IMMICH_VERSION}
    container_name: immich-server
    restart: unless-stopped
    ports:
      - "2283:2283"
    volumes:
      - ${UPLOAD_LOCATION}:/data:rw
      - /mnt/data/media/Photos:/mnt/media/Photos:ro
      - /mnt/data/family/Photos:/mnt/family/Photos:ro
      - /etc/localtime:/etc/localtime:ro
    environment:
      DB_PASSWORD: ${DB_PASSWORD}
      DB_USERNAME: ${DB_USERNAME}
      DB_DATABASE_NAME: ${DB_DATABASE_NAME}
      DB_HOSTNAME: immich-postgres
      REDIS_HOSTNAME: immich-redis
      TZ: ${TIMEZONE}
    group_add:
      - "${MEDIA_GROUP_GID}"  # media group GID for read access to external libraries
    depends_on:
      immich-postgres:
        condition: service_healthy
      immich-redis:
        condition: service_healthy
    networks:
      - homeserver
    healthcheck:
      test: ["CMD", "immich-healthcheck"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    deploy:
      resources:
        limits:
          cpus: "2.0"
          memory: 2G
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"

  immich-ml:
    image: ghcr.io/immich-app/immich-machine-learning:${IMMICH_VERSION}
    container_name: immich-ml
    restart: unless-stopped
    volumes:
      - model-cache:/cache:rw
    environment:
      TZ: ${TIMEZONE}
    networks:
      - homeserver
    healthcheck:
      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:3003/ping')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s
    deploy:
      resources:
        limits:
          cpus: "4.0"
          memory: 4G
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "3"

  immich-redis:
    image: docker.io/valkey/valkey:9
    container_name: immich-redis
    restart: unless-stopped
    networks:
      - homeserver
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 512M
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  immich-postgres:
    image: ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0
    container_name: immich-postgres
    restart: unless-stopped
    volumes:
      - ${DB_DATA_LOCATION}:/var/lib/postgresql/data:rw
    environment:
      POSTGRES_USER: ${DB_USERNAME}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_DATABASE_NAME}
      POSTGRES_INITDB_ARGS: '--data-checksums'
      TZ: ${TIMEZONE}
    shm_size: 128mb
    networks:
      - homeserver
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USERNAME} -d ${DB_DATABASE_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    deploy:
      resources:
        limits:
          cpus: "2.0"
          memory: 2G
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "3"

volumes:
  model-cache:

networks:
  homeserver:
    external: true
