# Foundation Configuration (System-Level)
# This file contains system-level configuration for the home server
# Copy to foundation.env and customize for your environment

# System Configuration
TIMEZONE="Europe/Amsterdam"              # System timezone (e.g., America/New_York, Europe/London)
HOSTNAME="homeserver"                    # Server hostname
SERVER_IP="192.168.1.2"                  # Server IP address (DHCP reservation recommended)
NETWORK_INTERFACE="enp0s3"               # Primary network interface

# User Configuration
ADMIN_USER="admin"                       # Admin username (non-root user with sudo)
ADMIN_EMAIL="admin@example.com"          # Admin email for notifications

# Disk Configuration
DATA_DISK="/dev/sdb"                     # Data disk device (for LUKS encryption)
DATA_MOUNT="/mnt/data"                   # Data mount point

# Git Configuration
GIT_USER_NAME="Admin User"               # Git commit author name
GIT_USER_EMAIL="admin@home.mydomain.com" # Git commit author email

# Notes:
# - This file should be readable by all users (644 permissions)
# - No sensitive data should be stored here
# - Sensitive data goes in secrets.env (600 permissions, root-only)
