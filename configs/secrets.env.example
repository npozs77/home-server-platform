# Secrets Configuration (Root-Protected)
# This file contains sensitive data that requires root/sudo to READ the file itself
# Copy to secrets.env and customize for your environment
#
# QUOTING: Always use SINGLE QUOTES for values (not double quotes).
# Double quotes cause bash to expand $, !, ` characters in passwords,
# which breaks sourcing under set -euo pipefail.

# LUKS Encryption
# IMPORTANT: This is the actual LUKS passphrase (not a Proton Pass reference)
# This file MUST have 600 permissions (root-only read/write)
LUKS_PASSPHRASE='strong-passphrase-20-plus-characters-here'

# Samba User Passwords
# Format: SAMBA_PASSWORD_<username>=<password>
# Minimum 8 characters, used for Samba authentication
SAMBA_PASSWORD_admin='admin-samba-password-here'
SAMBA_PASSWORD_dad='dad-samba-password-here'
SAMBA_PASSWORD_son1='son1-samba-password-here'
SAMBA_PASSWORD_mom='mom-samba-password-here'
SAMBA_PASSWORD_son2='son2-samba-password-here'

# Phase 4: Immich Secrets
DB_PASSWORD='strong-random-password-here'           # PostgreSQL password (Immich official var name)
IMMICH_API_KEY='immich-admin-api-key-here'           # Admin API key (obtained after setup wizard)

# Phase 4: Immich User Passwords (optional, pre-set or auto-generated)
# If not set, task-ph4-05-provision-immich-users.sh generates random 16-char
# passwords and appends them here automatically
# IMMICH_PASSWORD_dad='immich-password-here'
# IMMICH_PASSWORD_mom='immich-password-here'
# IMMICH_PASSWORD_son1='immich-password-here'
# IMMICH_PASSWORD_son2='immich-password-here'

# Phase 5: Wiki.js Secrets (Sub-phase A)
WIKI_DB_PASSWORD='strong-random-password-here'      # Wiki PostgreSQL password
WIKI_API_TOKEN='wiki-api-token-here'                # Wiki.js API token (obtained after setup wizard)

# Phase 5: Open WebUI Secrets (Sub-phase B)
OPENWEBUI_API_TOKEN='openwebui-api-token-here'      # Open WebUI API token (obtained after first-user setup)

# Phase 5: Wiki.js User Passwords (optional, pre-set or auto-generated)
# WIKI_PASSWORD_dad='wiki-password-here'
# WIKI_PASSWORD_mom='wiki-password-here'
# WIKI_PASSWORD_son1='wiki-password-here'
# WIKI_PASSWORD_son2='wiki-password-here'

# Phase 5: Open WebUI User Passwords (optional, pre-set or auto-generated)
# OPENWEBUI_PASSWORD_dad='openwebui-password-here'
# OPENWEBUI_PASSWORD_mom='openwebui-password-here'
# OPENWEBUI_PASSWORD_son1='openwebui-password-here'
# OPENWEBUI_PASSWORD_son2='openwebui-password-here'

# Security Requirements:
# 1. File permissions MUST be 600 (root-only read/write)
#    chmod 600 /opt/homeserver/configs/secrets.env
# 2. File owner MUST be root
#    chown root:root /opt/homeserver/configs/secrets.env
# 3. Never commit this file to Git
#    Add to .gitignore: secrets.env
# 4. Store backup copy in secure location (password manager, encrypted USB)

# Notes:
# - This file contains ACTUAL SECRETS (not references)
# - Proton Pass item IDs are NOT secrets and belong in services.env
# - Only secrets that require sudo to read the file itself go here
# - Most passwords should be fetched from Proton Pass at runtime (not stored here)
