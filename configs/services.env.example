# Services Configuration (Service-Specific)
# This file contains service-specific configuration for infrastructure services
# Copy to services.env and customize for your environment

# Domain Configuration
DOMAIN="mydomain.com"                    # Registered public domain
INTERNAL_SUBDOMAIN="home.mydomain.com"   # Internal subdomain for services

# SMTP Configuration (SMTP2GO)
SMTP2GO_HOST="mail-eu.smtp2go.com"       # SMTP relay host
SMTP2GO_PORT="2525"                      # SMTP relay port
SMTP2GO_FROM="alerts@home.mydomain.com"  # From address for notifications
SMTP2GO_USER="username"                  # SMTP username

# Proton Pass Configuration
# IMPORTANT: These are Proton Pass ITEM IDs (references), NOT the actual passwords
# The actual passwords are fetched from Proton Pass at runtime
HOMESERVER_PASS_SHARE_ID="vault-share-id-here"  # Proton Pass vault/share ID
SMTP2GO_PASS_ITEM_ID="item-id-here"             # Proton Pass item ID for SMTP2GO password
PIHOLE_PASS_ITEM_ID="item-id-here"              # Proton Pass item ID for Pi-hole password

# Phase 3: Core Services Configuration
# User Configuration
POWER_USERS="dad son1"                   # Power user usernames (space-separated)
STANDARD_USERS="mom son2"                # Standard user usernames (space-separated)

# Samba Configuration
SAMBA_WORKGROUP="WORKGROUP"              # Samba workgroup name
SAMBA_SERVER_STRING="Home Media Server"  # Samba server description

# Jellyfin Configuration
JELLYFIN_SERVER_NAME="Home Media Server" # Jellyfin server display name

# Notes:
# - This file should be readable by all users (644 permissions)
# - Proton Pass item IDs are NOT secrets (they're just references)
# - Actual passwords are fetched from Proton Pass using pass-cli
# - User must be logged into pass-cli before running deployment scripts
# - No sensitive data should be stored here
# - Sensitive data goes in secrets.env (600 permissions, root-only)
