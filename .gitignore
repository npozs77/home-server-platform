# Sensitive files
*.key
*.pem
*.env
!*.env.example
.env
*.secret
*.yaml
!*.yaml.example
!*.yml.example

# Backup files
*.backup*
*.bak
*~

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo


# Sensitive configuration files (restore from backups, not Git)
configs/.env
configs/*-config.env
configs/secrets.env
configs/caddy/Caddyfile
configs/caddy/root-ca.crt
configs/caddy/data/
configs/caddy/config/
configs/pihole/*.conf
configs/pihole/*.list
configs/samba/smb.conf
configs/pihole/etc-pihole/
configs/pihole/etc-dnsmasq.d/
configs/netdata/

# Docker Compose deployed files (contain real values from env; only .yml.example is Git-tracked)
configs/docker-compose/*.yml
!configs/docker-compose/*.yml.example

# Service persistent data (managed by Docker, not Git)
configs/docker-compose/*/data/
configs/docker-compose/*/config/

# PII-sensitive config (contains real domain/usernames for gitleaks scanning)
.gitleaks.toml

# Old PoC files + Input Documentation (such as concepts, ideas)
OLD/
input/
.kiro/hooks/
``